# Copy this file to phone.env.local. That local file is ignored by Git.
# The default is safe for demos: no real phone call leaves this computer.
CALL_PROVIDER=demo

# Set CALL_PROVIDER=twilio and fill every value below to place real calls.
# Use live Twilio credentials, not Twilio test credentials.
# TWILIO_FROM_NUMBER must be a voice-capable Twilio number or verified caller ID
# that belongs to your account. Keep PHONE_ALLOWLIST restricted to numbers you own.
# CALL_PROVIDER=twilio
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your_live_auth_token
# TWILIO_FROM_NUMBER=+YOUR_TWILIO_VOICE_NUMBER
# PHONE_ALLOWLIST=+48123456789

# Optional: a public HTTPS URL is needed for keypad responses and live call status.
# localhost and 127.0.0.1 cannot receive Twilio callbacks.
# PUBLIC_BASE_URL=https://your-public-domain.example
